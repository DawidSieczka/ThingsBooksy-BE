{
  "app": {
    "name": "ThingsBooksy",
    "version": "v1"
  },
  "auth": {
    "jwt": {
      "issuer": "thingsbooksy",
      "audience": "thingsbooksy",
      "validIssuer": "thingsbooksy",
      "validAudience": "thingsbooksy",
      "validateAudience": true,
      "validateIssuer": true,
      "validateLifetime": true,
      "issuerSigningKey": "CHANGE_ME_use_a_long_random_secret_key_at_least_32_chars",
      "expiry": "07.00:00:00"
    }
  },
  "cors": {
    "allowCredentials": true,
    "allowedOrigins": [ "http://localhost:3000" ],
    "allowedMethods": [ "POST", "PUT", "DELETE" ],
    "allowedHeaders": [ "Content-Type", "Authorization" ],
    "exposedHeaders": [ "Resource-ID" ]
  },
  "logger": {
    "level": "information",
    "overrides": {
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
    },
    "excludePaths": [ "/", "/ping" ],
    "excludeProperties": [ "api_key", "Password", "Email", "Token", "Secret" ],
    "console": { "enabled": true },
    "file": { "enabled": true, "path": "logs/logs.txt", "interval": "day" }
  },
  "users": {
    "module": { "enabled": true }
  },
  "messaging": { "useAsyncDispatcher": true },
  "outbox": { "enabled": false, "interval": "00:00:01" },
  "postgres": {
    "connectionString": "Host=localhost;Database=thingsbooksy;Username=postgres;Password="
  },
  "security": {
    "encryption": {
      "enabled": true,
      "key": "CHANGE_ME_32chars_encryption_key"
    }
  }
}
